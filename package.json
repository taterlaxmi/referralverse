{
  "name": "referral-verse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "postbuild": "next-sitemap",
    "test": "vitest run",
    "test:audit": "node tests/audit/run.mjs https://referralverse.in",
    "test:lighthouse": "lhci autorun --config=tests/audit/lighthouserc.js",
    "test:report": "node tests/audit/aggregate-report.mjs",
    "test:all": "npm run test && npm run test:audit && npm run test:report"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.7",
    "@supabase/supabase-js": "^2.108.2",
    "cheerio": "^1.2.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "react": "19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@lhci/cli": "^0.15.1",
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-config-next": "16.2.7",
    "googleapis": "^173.0.0",
    "jsdom": "^29.1.1",
    "next-sitemap": "^4.2.3",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "tmp": "^0.2.7"
  }
}
